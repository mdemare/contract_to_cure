<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%= csrf_meta_tags %>
  <title>Pandemic: Global Disease Control</title>
  <link rel="stylesheet" href="/css/buttons.css">
  <link rel="stylesheet" href="/css/card_animation.css">
  <link rel="stylesheet" href="/css/card_selection.css">
  <link rel="stylesheet" href="/css/current_player.css">
  <link rel="stylesheet" href="/css/game_over.css">
  <link rel="stylesheet" href="/css/interface.css">
  <link rel="stylesheet" href="/css/map.css">
  <link rel="stylesheet" href="/css/notification.css">
  <link rel="stylesheet" href="/css/player_cards.css">
  <link rel="stylesheet" href="/css/player_panel.css">
  <link rel="stylesheet" href="/css/share_knowledge.css">
  <link rel="stylesheet" href="/css/player_selection.css">
  <link rel="stylesheet" href="/css/style.css">  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Roboto+Slab:wght@400;700&display=swap" rel="stylesheet">
  <script type="module" src="/js/auth.js"></script>
  <script type="module" src="/js/action_buttons.js"></script>
  <script type="module" src="/js/constants.js"></script>
  <script type="module" src="/js/current_player.js"></script>
  <script type="module" src="/js/end_turn_events.js"></script>
  <script type="module" src="/js/events.js"></script>
  <script type="module" src="/js/game_state.js"></script>
  <script type="module" src="/js/game_over.js"></script>
  <script type="module" src="/js/map.js"></script>
  <script type="module" src="/js/player_actions.js"></script>
  <script type="module" src="/js/player_panel.js"></script>
  <script type="module" src="/js/scrolling.js"></script>
  <script type="module" src="/js/retrieve_card.js"></script>
</head>
<body>
  <div class="game-header">
    <div class="logo-container">
      <h1>PANDEMIC</h1>
      <h2>Global Disease Control</h2>
    </div>
    <% if Rails.env.production? %>
      <span class="git-hash"><%= File.read('.git/refs/heads/trunk').strip[0..5] rescue nil %></span>
    <% end %>
    <div class="auth-container">
      <div id="auth-info" style="display: none;">
        <span class="user-name"></span>
        <button id="logout-btn" class="logout-button">Logout</button>
      </div>
      <a id="login-btn" href="/login" class="login-button" style="display: none;">Login with Google</a>
    </div>
  </div>

  <div class="game-interface">
    <div class="game-status">
      <div class="status-panel">
        <h3>Game Status</h3>
        <div class="status-item">
          <span>Actions:</span>
          <span id="action-counter">0</span>
        </div>
        <div class="status-item">
          <span>Turn:</span>
          <span id="turn-counter">1</span>
        </div>
        <div class="status-item">
          <span>Outbreaks:</span>
          <span id="outbreak-counter">0</span>
        </div>
        <div class="status-item">
          <span>Player Cards:</span>
          <span id="player-cards">35</span>
        </div>
      </div>

      <div class="cure-status">
        <h3>Disease Status</h3>
        <div class="cure-grid">
          <div class="cure-item blue">
            <div class="cure-color"></div>
            <div id="blue-cure" class="cure-label">Not Cured</div>
            <div id="blue-cubes" class="cube-count">24 cubes</div>
          </div>
          <div class="cure-item yellow">
            <div class="cure-color"></div>
            <div id="yellow-cure" class="cure-label">Not Cured</div>
            <div id="yellow-cubes" class="cube-count">24 cubes</div>
          </div>
          <div class="cure-item black">
            <div class="cure-color"></div>
            <div id="black-cure" class="cure-label">Not Cured</div>
            <div id="black-cubes" class="cube-count">24 cubes</div>
          </div>
          <div class="cure-item red">
            <div class="cure-color"></div>
            <div id="red-cure" class="cure-label">Not Cured</div>
            <div id="red-cubes" class="cube-count">24 cubes</div>
          </div>
        </div>
      </div>
    </div>

    <div class="map-wrapper">
      <div class="map-container">
        <svg class="connections-layer" width="100%" height="100%"></svg>
      </div>
    </div>
  </div>

  <div class="current-player">
    <div class="current-player-pawn" id="current-player-pawn"></div>
    <div class="current-player-label" id="current-player-label">Current Player</div>
  </div>

  <!-- Touch-Friendly Action Buttons -->
  <div class="action-buttons">
    <button id="move-btn" class="action-btn move">
      <i></i>
      <span>Move</span>
    </button>
    <button id="treat-btn" class="action-btn treat">
      <i></i>
      <span>Treat</span>
    </button>
    <button id="share-btn" class="action-btn share">
      <i></i>
      <span>Share</span>
    </button>
    <div class="player-hand-container">
      <div class="player-hand">
        <!-- Cards will be dynamically added here -->
      </div>
    </div>
    <button id="cure-btn" class="action-btn cure">
      <i></i>
      <span>Cure</span>
    </button>
    <button id="build-btn" class="action-btn build">
      <i></i>
      <span>Build</span>
    </button>
    <button id="retrieve-btn" class="action-btn retrieve">
      <i></i>
      <span>Retrieve</span>
    </button>
    <button id="pass-btn" class="action-btn pass">
      <i></i>
      <span>Pass</span>
    </button>
    <button id="infect-cities-btn" class="action-btn infect-cities" style="display: none">
      <i></i>
      <span>Infect Cities</span>
    </button>
    <button id="draw-cards-btn" class="action-btn draw-cards" style="display: none">
      <i></i>
      <span>Draw Cards</span>
    </button>
  </div>
</body>
</html>
