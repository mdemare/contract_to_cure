# Google OAuth Configuration
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select an existing one
# 3. Enable the Google+ API
# 4. Go to Credentials and create an OAuth 2.0 Client ID
# 5. Set authorized redirect URIs:
#    - http://localhost:3000/auth/google_oauth2/callback (for development)
#    - https://yourdomain.com/auth/google_oauth2/callback (for production)
# 6. Copy the Client ID and Client Secret below

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Optional: Skip authentication in development
# SKIP_AUTH=true

# Redis configuration (if different from default)
# REDIS_URL=redis://localhost:6379
# REDIS_POOL_SIZE=5
# REDIS_POOL_TIMEOUT=5
